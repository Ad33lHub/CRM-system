# ── App ──────────────────────────────────────────
# Port the API listens on / runtime mode / allowed client origin for CORS
PORT=
NODE_ENV=
CLIENT_URL=
APP_NAME=
APP_VERSION=

# ── MongoDB ──────────────────────────────────────
# Atlas connection string (prod/dev) and a local URI used by the test suite
MONGODB_URI=
MONGODB_URI_TEST=

# ── Redis ────────────────────────────────────────
# Cache / session store connection (password optional for local)
REDIS_URL=
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────
# Access/refresh signing secrets (>=64 random chars) and their lifetimes
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=
JWT_REFRESH_EXPIRES_IN=

# ── Bcrypt ───────────────────────────────────────
# Password hashing cost factor (project standard: 12)
BCRYPT_SALT_ROUNDS=

# ── Cloudinary (optional) ────────────────────────
# Media storage credentials; uploads disabled if unset
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (SMTP) ─────────────────────────────────
# Outbound mail transport and default From identity
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=
EMAIL_FROM_ADDRESS=

# ── Rate Limiting ────────────────────────────────
# Global window/limit plus a stricter cap for auth endpoints
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX_REQUESTS=
AUTH_RATE_LIMIT_MAX=

# ── Logging ──────────────────────────────────────
# Winston log level and output directory
LOG_LEVEL=
LOG_DIR=

# ── BullMQ ───────────────────────────────────────
# Redis connection for background job queues (defaults to REDIS_URL)
BULL_REDIS_URL=

# ── AI (Phase 11 — optional) ─────────────────────
# OpenAI credentials; AI features disabled if unset
OPENAI_API_KEY=
OPENAI_MODEL=
