# ── App ──────────────────────────────────────────
# Display name / version / runtime mode surfaced in the UI
VITE_APP_NAME=
VITE_APP_VERSION=
VITE_ENV=

# ── API ──────────────────────────────────────────
# REST base URL and Socket.IO origin (proxied to the server in dev)
VITE_API_URL=
VITE_SOCKET_URL=

# ── Cloudinary (public — upload preset only) ─────
# Public cloud name and unsigned upload preset; never put the API secret here
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
